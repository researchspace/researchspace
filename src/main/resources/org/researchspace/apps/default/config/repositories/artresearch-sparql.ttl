@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix config: <tag:rdf4j.org,2023:config/> .

[] a config:Repository ;
   config:rep.id "artresearch-sparql" ;
   rdfs:label "ArtResearch SPARQL Endpoint" ;
   config:rep.impl [
      config:rep.type "researchspace:SPARQLRepository" ;
      config:sparql.queryEndpoint <https://artresearch.net/sparql?nocache=1>
   ] .
