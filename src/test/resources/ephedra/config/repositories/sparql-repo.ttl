@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix config: <tag:rdf4j.org,2023:config/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix mph: <http://www.researchspace.org/resource/system/repository#> .

[] a config:Repository ;
   config:rep.id "sparql-repo" ;
   rdfs:label "Test SPARQL HTTP Repository" ;
   config:rep.impl [
      config:rep.type "researchspace:SPARQLRepository" ;
      config:sparql.queryEndpoint <http://localhost:18089/sparql>
   ] .
